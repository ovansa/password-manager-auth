{
  "name": "password-manager-auth",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "generate-key": "tsx scripts/generate-key.ts",
    "migrate-users": "tsx scripts/migrate-existing-users.ts"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "setupFiles": ["./tests/setup.ts"],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "tsconfig": "tests/tsconfig.json" }]
    },
    "moduleFileExtensions": ["ts", "tsx", "js", "json"]
  },
  "keywords": [
    "oauth",
    "password-manager",
    "authentication"
  ],
  "author": "Muhammed Ibrahim <ovansa.im@gmail.com>",
  "license": "ISC",
  "packageManager": "pnpm@10.12.1",
  "dependencies": {
    "axios": "^1.11.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "firebase": "^12.1.0",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
